packages: .

-- Allow newer versions of template-haskell to work with uuid-types and aeson
-- This workaround is needed for newer GHC versions where packages haven't yet declared support
-- Allow newer base for entire dependency tree to work with GHC 9.12+ (base 4.22+)
-- This is needed because servant ecosystem hasn't fully caught up to latest GHC
allow-newer: uuid-types:template-haskell, *:base, *:template-haskell
